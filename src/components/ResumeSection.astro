---
interface Props { id: string; title: string; }
const { id, title } = Astro.props;
---
<section id={id} class="resume-section">
  <h2>{title}</h2>
  <div class="resume-section__body">
    <slot />
  </div>
</section>
<style>
  .resume-section { padding: var(--space-12) 0; scroll-margin-top: var(--space-12); }
  /* Subtle divider between sections (skip the first). */
  .resume-section + .resume-section {
    border-top: 1px solid var(--border);
  }
  .resume-section h2 {
    font-family: var(--font-display);
    font-size: clamp(1.75rem, 3.5vw, 2.25rem);
    font-weight: 700;
    line-height: 1.15;
    letter-spacing: -0.015em;
    text-transform: none;
    color: var(--accent);
    margin: 0 0 var(--space-6);
  }
  .resume-section__body { color: var(--fg); font-family: var(--font-sans); }
</style>