---
import { PROFILE } from '../lib/profile';

const sections = [
  { id: 'about', label: 'About' },
  { id: 'skills', label: 'Skills' },
  { id: 'experience', label: 'Experience' },
  { id: 'education', label: 'Education' },
  { id: 'certifications', label: 'Certifications' },
  { id: 'projects', label: 'Projects' },
  { id: 'contact', label: 'Contact' },
];
---
<aside class="resume-sidebar">
  <div>
    <h1>{PROFILE.name}</h1>
    <p class="resume-sidebar__role">{PROFILE.title}</p>
    <p class="resume-sidebar__bio">{PROFILE.tagline}</p>
  </div>

  <nav aria-label="Section navigation" class="resume-sidebar__nav">
    <ul>
      {sections.map((s) => (
        <li>
          <a href={`#${s.id}`} data-nav-id={s.id}>
            <span class="resume-sidebar__bar" aria-hidden="true"></span>
            {s.label}
          </a>
        </li>
      ))}
    </ul>
  </nav>

  <ul class="resume-sidebar__socials" aria-label="Social links">
    <li>
      <a
        href={PROFILE.socials.github}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub profile (opens in new tab)"
        title="GitHub"
      >
        <svg
          class="resume-sidebar__icon"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          focusable="false"
        >
          <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"/>
        </svg>
      </a>
    </li>
    <li>
      <a
        href={PROFILE.socials.linkedin}
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn profile (opens in new tab)"
        title="LinkedIn"
      >
        <svg
          class="resume-sidebar__icon"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          focusable="false"
        >
          <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
          <rect x="2" y="9" width="4" height="12"/>
          <circle cx="4" cy="4" r="2"/>
        </svg>
      </a>
    </li>
    <li>
      <a
        href={`mailto:${PROFILE.socials.email}`}
        aria-label={`Email ${PROFILE.socials.email}`}
        title="Email"
      >
        <svg
          class="resume-sidebar__icon"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          aria-hidden="true"
          focusable="false"
        >
          <rect x="2" y="4" width="20" height="16" rx="2"/>
          <polyline points="22,7 12,13 2,7"/>
        </svg>
      </a>
    </li>
  </ul>
</aside>

<script>
  // Scroll-spy: highlight the section currently in view.
  const links = document.querySelectorAll<HTMLAnchorElement>('[data-nav-id]');
  const idToLink = new Map<string, HTMLAnchorElement>();
  links.forEach((a) => idToLink.set(a.dataset.navId!, a));

  const obs = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        const link = idToLink.get(e.target.id);
        if (!link) continue;
        if (e.isIntersecting) {
          links.forEach((l) => l.removeAttribute('aria-current'));
          link.setAttribute('aria-current', 'true');
        }
      }
    },
    { rootMargin: '-40% 0px -55% 0px' },
  );
  document.querySelectorAll<HTMLElement>('main section[id]').forEach((s) => obs.observe(s));
</script>

<style>
  .resume-sidebar {
    position: fixed;
    top: 3.5rem;
    height: calc(100vh - 3.5rem);
    /* Match the left edge + width of the grid's first column inside .page-main--wide (max 80rem, padding 3rem each side, gap 3rem) */
    left: calc(max(0px, (100vw - 80rem) / 2) + 3rem);
    width: calc((min(100vw, 80rem) - 9rem) / 2 * 0.8);
    display: flex; flex-direction: column; justify-content: space-between;
    padding: var(--space-4) 0 var(--space-6);
    overflow: hidden;
  }
  .resume-sidebar h1 {
    margin: 0 0 var(--space-2);
    font-size: var(--type-3xl);
    color: var(--fg);
  }
  .resume-sidebar__role {
    margin: 0; color: var(--accent); font-family: var(--font-mono);
  }
  .resume-sidebar__bio {
    color: var(--fg-muted);
    font-family: var(--font-sans);
    margin-top: var(--space-4);
    line-height: 1.75;
  }
  .resume-sidebar__nav ul {
    list-style: none; padding: 0; margin: 0;
    display: flex; flex-direction: column; gap: var(--space-3);
  }
  .resume-sidebar__nav a {
    display: inline-flex; align-items: center; gap: var(--space-3);
    color: var(--fg-muted); font-family: var(--font-mono);
    font-size: var(--type-sm); text-transform: uppercase; letter-spacing: 0.08em;
  }
  .resume-sidebar__nav a:hover { color: var(--accent); text-decoration: none; }
  .resume-sidebar__nav a:hover .resume-sidebar__bar {
    width: 2.25rem;
    background: var(--accent);
  }
  .resume-sidebar__bar {
    display: inline-block; width: 1.5rem; height: 1px; background: var(--fg-muted);
    transition: width 200ms ease, background 200ms ease;
  }
  .resume-sidebar__nav a[aria-current="true"] { color: var(--accent); }
  .resume-sidebar__nav a[aria-current="true"] .resume-sidebar__bar {
    width: 3rem; background: var(--accent);
  }
  .resume-sidebar__socials {
    list-style: none; padding: 0; margin: auto 0 0;
    display: flex; gap: var(--space-4);
    font-family: var(--font-mono); font-size: var(--type-sm);
  }
  .resume-sidebar__socials a {
    display: inline-flex; align-items: center; justify-content: center;
    color: var(--fg-muted);
    padding: var(--space-2);
    border-radius: var(--radius-sm);
    transition: color 200ms ease, background 200ms ease, transform 200ms ease;
  }
  .resume-sidebar__socials a:hover,
  .resume-sidebar__socials a:focus-visible {
    color: var(--accent);
    background: var(--accent-soft);
    text-decoration: none;
    transform: translateY(-1px);
  }
  .resume-sidebar__icon {
    width: 1.25rem; height: 1.25rem;
    display: block;
  }
  @media (max-width: 1024px) {
    .resume-sidebar {
      position: static;
      height: auto;
      width: auto;
      left: auto;
      padding: 0;
    }
  }
</style>