      <div class="gallery__tile" aria-label="Placeholder photo 5"></div>
      <div class="gallery__tile" aria-label="Placeholder photo 6"></div>
    </div>
  </section>

  <section class="real-section">
    <h2>Fun facts</h2>
    <ul>
      <li>I once debugged a production outage from a mountain.</li>
