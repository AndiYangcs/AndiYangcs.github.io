---
import BaseLayout from './BaseLayout.astro';
import { TopNav } from '../components/TopNav';

interface Props {
  title: string;
  persona: 'professional' | 'real';
  description?: string;
  wide?: boolean;
}
const { title, persona, description, wide = false } = Astro.props;
---
<BaseLayout title={title} description={description}>
  <TopNav persona={persona} client:load />
  <main class={'page-main' + (wide ? ' page-main--wide' : '')}>
    <slot />
  </main>

  <style>
    .page-main {
      max-width: var(--max-content-w);
      margin: 0 auto;
      padding: var(--space-16) var(--space-4) var(--space-12);
    }
    .page-main--wide {
      max-width: 80rem;
      padding: var(--space-16) var(--space-12) var(--space-12);
    }
    @media (max-width: 1024px) {
      .page-main--wide { padding: var(--space-16) var(--space-4) var(--space-12); }
    }
  </style>
</BaseLayout>
